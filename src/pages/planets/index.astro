---
import Layout from '../../components/layout/Layout.astro';
import ConsumableCard from '../../components/cards/ConsumableCard.astro';
import SearchBox from '../../components/ui/SearchBox.astro';
import planets from '../../data/planets.json';
---

<Layout title="Planets" description="Browse all Balatro Odyssey Planet cards.">
  <div class="px-[5%] py-12 max-w-[1400px] mx-auto">
    <div class="mb-8">
      <p class="text-accent text-[0.8rem] font-bold uppercase tracking-[0.1em] mb-2">Browse</p>
      <h1 class="font-extrabold text-white mb-1" style="font-size: clamp(1.8rem, 3vw, 2.6rem);">
        <span class="lang-en">Planets</span>
        <span class="lang-pt">Planetas</span>
      </h1>
      <p class="text-muted">{planets.length} <span class="lang-en">cards total</span><span class="lang-pt">cartas no total</span></p>
    </div>
    <SearchBox placeholder_en="Search planets..." placeholder_pt="Buscar planetas..." />
    <div class="grid gap-4" style="grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));">
      {planets.map(item => <ConsumableCard item={item} />)}
    </div>
  </div>
</Layout>
