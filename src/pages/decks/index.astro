---
import Layout from '../../components/layout/Layout.astro';
import DeckCard from '../../components/cards/DeckCard.astro';
import SearchBox from '../../components/ui/SearchBox.astro';
import decks from '../../data/decks.json';
---

<Layout title="Decks" description="Browse all Balatro Odyssey Decks.">
  <div class="px-[5%] py-12 max-w-[1400px] mx-auto">
    <div class="mb-8">
      <p class="text-accent text-[0.8rem] font-bold uppercase tracking-[0.1em] mb-2">Browse</p>
      <h1 class="font-extrabold text-white mb-1" style="font-size: clamp(1.8rem, 3vw, 2.6rem);">
        <span class="lang-en">Decks</span>
        <span class="lang-pt">Baralhos</span>
      </h1>
      <p class="text-muted">{decks.length} <span class="lang-en">decks total</span><span class="lang-pt">baralhos no total</span></p>
    </div>

    <SearchBox placeholder_en="Search decks..." placeholder_pt="Buscar baralhos..." />

    <div id="deck-grid" class="grid gap-4" style="grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));">
      {decks.map(deck => <DeckCard deck={deck} />)}
    </div>
  </div>
</Layout>
