---
import Layout from '../../components/layout/Layout.astro';
import ConsumableCard from '../../components/cards/ConsumableCard.astro';
import SearchBox from '../../components/ui/SearchBox.astro';
import tarots from '../../data/tarots.json';
import { consumableLoreByType } from '../../data/lore';

const lore = consumableLoreByType['tarot'];
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Tarots" description="Browse all 100 custom Tarot cards in Balatro Odyssey mod. Each Tarot offers a powerful new effect that reshapes your hand, deck or game strategy.">
  <div class="px-[5%] py-12 max-w-[1400px] mx-auto">
    <div class="mb-6">
      <p class="text-accent text-[0.8rem] font-bold uppercase tracking-[0.1em] mb-2">Browse</p>
      <h1 class="font-extrabold text-white mb-1" style="font-size: clamp(1.8rem, 3vw, 2.6rem);">
        <span class="lang-en">Tarots</span>
        <span class="lang-pt">Tarôs</span>
      </h1>
      <p class="text-muted">{tarots.length} <span class="lang-en">cards total</span><span class="lang-pt">cartas no total</span></p>
    </div>

    <!-- Lore intro -->
    <div class="mb-8 rounded-2xl border p-6 flex gap-4 items-start" style="background: rgba(108,71,255,0.08); border-color: rgba(108,71,255,0.25);">
      <div class="text-3xl mt-0.5 flex-shrink-0">🔮</div>
      <div>
        <p class="text-[0.78rem] font-black uppercase tracking-wider mb-2" style="color: var(--accent);"><span class="lang-en">Lore</span><span class="lang-pt">Lore</span></p>
        <p class="text-sm leading-relaxed lang-en" style="color: var(--muted);">{lore.intro_en}</p>
        <p class="text-sm leading-relaxed lang-pt" style="color: var(--muted);">{lore.intro_pt}</p>
        <a href={`${base}/lore#consumables`} class="inline-block mt-3 text-xs font-semibold hover:underline" style="color: var(--primary);">
          <span class="lang-en">Read full Odyssey narrative →</span>
          <span class="lang-pt">Ler narrativa completa da Odisseia →</span>
        </a>
      </div>
    </div>

    <SearchBox placeholder_en="Search tarots..." placeholder_pt="Buscar tarôs..." />

    <div id="tarot-grid" class="grid gap-4" style="grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));">
      {tarots.map(item => <ConsumableCard item={item} />)}
    </div>
  </div>
</Layout>
