---
import LangToggle from '../ui/LangToggle.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<nav class="sticky top-0 z-50 h-16 flex items-center justify-between px-[5%] border-b border-[var(--border)]"
     style="background: rgba(13,13,26,0.92); backdrop-filter: blur(12px);">

  <!-- Logo -->
  <a href={base + '/'} class="flex items-center gap-2 font-black text-lg text-white no-underline hover:text-[var(--accent)] transition-colors">
    <span class="text-[var(--primary)]">✦</span>
    <span>Balatro Odyssey Wiki</span>
  </a>

  <!-- Nav links (hidden on mobile) -->
  <ul class="hidden md:flex items-center gap-6 list-none text-[0.95rem]">
    <li>
      <a href={base + '/jokers'} class="text-muted hover:text-white transition-colors">
        <span class="lang-en">Jokers</span>
        <span class="lang-pt">Curingas</span>
      </a>
    </li>
    <li>
      <a href={base + '/decks'} class="text-muted hover:text-white transition-colors">
        <span class="lang-en">Decks</span>
        <span class="lang-pt">Baralhos</span>
      </a>
    </li>
    <li>
      <a href={base + '/tarots'} class="text-muted hover:text-white transition-colors">
        <span class="lang-en">Tarots</span>
        <span class="lang-pt">Tarôs</span>
      </a>
    </li>
    <li>
      <a href={base + '/planets'} class="text-muted hover:text-white transition-colors">
        <span class="lang-en">Planets</span>
        <span class="lang-pt">Planetas</span>
      </a>
    </li>
    <li>
      <a href={base + '/spectrals'} class="text-muted hover:text-white transition-colors">
        <span class="lang-en">Spectrals</span>
        <span class="lang-pt">Espectrais</span>
      </a>
    </li>
    <li>
      <a href={base + '/vouchers'} class="text-muted hover:text-white transition-colors">
        <span class="lang-en">Vouchers</span>
        <span class="lang-pt">Cupons</span>
      </a>
    </li>
    <li>
      <a href={base + '/blinds'} class="text-muted hover:text-white transition-colors">Blinds</a>
    </li>
    <li>
      <a href={base + '/hands'} class="text-muted hover:text-white transition-colors">
        <span class="lang-en">Hands</span>
        <span class="lang-pt">Mãos</span>
      </a>
    </li>
    <li class="flex items-center gap-1.5">
      <span class="text-muted opacity-40 cursor-not-allowed select-none">Tags</span>
      <span class="text-[0.6rem] font-bold uppercase tracking-wider px-1.5 py-0.5 rounded border border-[var(--border)] text-muted opacity-50">
        <span class="lang-en">Soon</span>
        <span class="lang-pt">Em Breve</span>
      </span>
    </li>
    <li>
      <a href={base + '/changelog'} class="text-muted hover:text-white transition-colors">Changelog</a>
    </li>
    <!-- Lore — pill button destacado -->
    <li>
      <a href={base + '/lore'}
         class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full text-[0.82rem] font-bold transition-all hover:scale-105 hover:brightness-110"
         style="background: rgba(0,212,170,0.15); border: 1px solid rgba(0,212,170,0.4); color: var(--accent);">
        ✦ Lore
      </a>
    </li>
  </ul>

  <!-- Right side: Lang toggle + mobile hamburguer -->
  <div class="flex items-center gap-3">
    <LangToggle />
    <!-- hamburguer (só mobile) -->
    <button id="nav-hamburger" class="md:hidden flex flex-col justify-center gap-[5px] w-9 h-9 rounded-lg border border-[var(--border)] p-2 hover:bg-white/5 transition-colors" aria-label="Menu">
      <span class="block w-full h-0.5 bg-white rounded"></span>
      <span class="block w-full h-0.5 bg-white rounded"></span>
      <span class="block w-full h-0.5 bg-white rounded"></span>
    </button>
  </div>
</nav>

<!-- Mobile drawer -->
<div id="nav-drawer" class="fixed inset-0 z-[200] flex flex-col" style="background: rgba(13,13,26,0.98); backdrop-filter: blur(16px); display: none !important;">
  <!-- cabeçalho do drawer -->
  <div class="flex items-center justify-between px-6 h-16 border-b" style="border-color: var(--border);">
    <a href={base + '/'} class="font-black text-lg text-white no-underline" id="nav-drawer-logo">
      <span class="text-[var(--primary)]">✦</span> Balatro Odyssey Wiki
    </a>
    <button id="nav-drawer-close" class="w-9 h-9 flex items-center justify-center rounded-lg border border-[var(--border)] text-white text-xl hover:bg-white/10 transition-colors" aria-label="Fechar menu">✕</button>
  </div>

  <!-- links -->
  <nav class="flex-1 overflow-y-auto px-6 py-6 flex flex-col gap-1">
    <!-- DESTAQUE: Lore -->
    <a href={base + '/lore'} id="nav-drawer-lore"
       class="flex items-center gap-3 px-4 py-3.5 rounded-xl font-bold text-base mb-3 transition-all"
       style="background: rgba(0,212,170,0.12); border: 1px solid rgba(0,212,170,0.35); color: var(--accent);">
      <span class="text-xl">✦</span>
      <span>
        <span class="lang-en">Lore — The Grand Narrative</span>
        <span class="lang-pt">Lore — A Grande Narrativa</span>
      </span>
    </a>

    {([
      { href: '/jokers',      icon: '🃏', en: 'Jokers',         pt: 'Curingas'    },
      { href: '/decks',       icon: '🎴', en: 'Decks',          pt: 'Baralhos'    },
      { href: '/tarots',      icon: '🌙', en: 'Tarots',         pt: 'Tarôs'       },
      { href: '/planets',     icon: '🪐', en: 'Planets',        pt: 'Planetas'    },
      { href: '/spectrals',   icon: '👻', en: 'Spectrals',      pt: 'Espectrais'  },
      { href: '/vouchers',    icon: '🏷️', en: 'Vouchers',       pt: 'Cupons'      },
      { href: '/blinds',      icon: '🎯', en: 'Blinds',         pt: 'Blinds'      },
      { href: '/hands',       icon: '🤚', en: 'Hands',          pt: 'Mãos'        },
      { href: '/changelog',   icon: '📋', en: 'Changelog',      pt: 'Changelog'   },
    ] as const).map(link => (
      <a href={base + link.href}
         class="nav-drawer-link flex items-center gap-3 px-4 py-3 rounded-xl text-[0.95rem] font-medium transition-all hover:bg-white/5 no-underline"
         style="color: var(--text);">
        <span class="w-6 text-center">{link.icon}</span>
        <span>
          <span class="lang-en">{link.en}</span>
          <span class="lang-pt">{link.pt}</span>
        </span>
      </a>
    ))}
  </nav>
</div>

<script>
  const hamburger = document.getElementById('nav-hamburger');
  const drawer    = document.getElementById('nav-drawer');
  const close     = document.getElementById('nav-drawer-close');
  const logo      = document.getElementById('nav-drawer-logo');
  const loreLink  = document.getElementById('nav-drawer-lore');

  function openDrawer()  { if (drawer) drawer.style.display = 'flex'; document.body.style.overflow = 'hidden'; }
  function closeDrawer() { if (drawer) drawer.style.display = 'none';  document.body.style.overflow = ''; }

  hamburger?.addEventListener('click', openDrawer);
  close?.addEventListener('click', closeDrawer);
  logo?.addEventListener('click', closeDrawer);
  loreLink?.addEventListener('click', closeDrawer);
  document.querySelectorAll('.nav-drawer-link').forEach(l => l.addEventListener('click', closeDrawer));

  // fecha ao clicar fora do painel
  drawer?.addEventListener('click', (e) => { if (e.target === drawer) closeDrawer(); });
</script>
