---
import LangToggle from '../ui/LangToggle.astro';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Balatro Odyssey Wiki', description = 'Your complete guide to the Balatro Odyssey mod.' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://fenomelini.github.io');
const path = Astro.url.pathname;

const navItems = [
  { href: base + '/',            icon: '✦',  label_en: 'Home',       label_pt: 'Início',     count: '' },
  { href: base + '/jokers',      icon: '🃏', label_en: 'Jokers',     label_pt: 'Curingas',   count: '1,000' },
  { href: base + '/decks',       icon: '🎴', label_en: 'Decks',      label_pt: 'Baralhos',   count: '100' },
  { href: base + '/tarots',      icon: '🌙', label_en: 'Tarots',     label_pt: 'Tarôs',      count: '100' },
  { href: base + '/planets',     icon: '🪐', label_en: 'Planets',    label_pt: 'Planetas',   count: '100' },
  { href: base + '/spectrals',   icon: '👻', label_en: 'Spectrals',  label_pt: 'Espectrais', count: '100' },
  { href: base + '/vouchers',    icon: '🏷️', label_en: 'Vouchers',   label_pt: 'Cupons',     count: '200' },
  { href: base + '/blinds',      icon: '🎯', label_en: 'Blinds',     label_pt: 'Blinds',     count: '100' },
  { href: base + '/hands',         icon: '🖐️', label_en: 'Hands',        label_pt: 'Mãos',           count: '67' },
  { href: base + '/enhancements',  icon: '✨', label_en: 'Enhancements', label_pt: 'Aprimoramentos', count: '17' },
  { href: null,                    icon: '🏷️', label_en: 'Tags',         label_pt: 'Tags',           count: '', disabled: true, soon: true },
  { href: base + '/changelog',   icon: '📋', label_en: 'Changelog',  label_pt: 'Changelog',  count: '' },
  { href: base + '/lore',        icon: '✦',  label_en: 'Lore',       label_pt: 'Lore',       count: '', lore: true },
];

function isActive(href: string) {
  if (href === base + '/') return path === href || path === base;
  return path.startsWith(href);
}
---
<!doctype html>
<html lang="en" data-lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <title>{title} | Balatro Odyssey Wiki</title>
  <style is:global>
    :root {
      --primary:      #6c47ff;
      --primary-dark: #4f2fe0;
      --accent:       #00d4aa;
      --dark:         #0d0d1a;
      --dark2:        #13132a;
      --dark3:        #1c1c3a;
      --card:         #18183a;
      --text:         #e8e8f0;
      --muted:        #9090b0;
      --border:       rgba(108,71,255,0.25);
      --sidebar-w:    260px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html {
      font-family: 'Segoe UI', system-ui, sans-serif;
      background: var(--dark);
      color: var(--text);
      line-height: 1.6;
      scroll-behavior: smooth;
    }

    body { min-height: 100vh; display: flex; }

    /* Language visibility */
    [data-lang="en"] .lang-pt { display: none !important; }
    [data-lang="pt"] .lang-en { display: none !important; }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--dark2); }
    ::-webkit-scrollbar-thumb { background: var(--primary); border-radius: 3px; }

    /* Sprites */
    img { image-rendering: pixelated; }
    img.sprite-error { opacity: 0.15; filter: grayscale(1); }

    /* Sidebar */
    #sidebar {
      width: var(--sidebar-w);
      flex-shrink: 0;
      position: sticky;
      top: 0;
      height: 100vh;
      display: flex;
      flex-direction: column;
      border-right: 1px solid var(--border);
      background: var(--dark2);
      overflow: hidden;
    }

    /* Main area */
    #main-area {
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
    }

    /* Mobile: sidebar hidden off-screen */
    @media (max-width: 767px) {
      body { display: block; }
      #sidebar {
        position: fixed;
        top: 0; left: 0; bottom: 0;
        z-index: 50;
        transform: translateX(-100%);
        transition: transform 0.28s ease;
        height: 100%;
      }
      #sidebar.open { transform: translateX(0); }
      #sidebar-overlay {
        display: none;
        position: fixed; inset: 0; z-index: 40;
        background: rgba(0,0,0,0.6);
      }
      #sidebar-overlay.open { display: block; }
      #main-area { padding-top: 3.5rem; }
      #mobile-topbar { display: flex !important; }
    }
    @media (min-width: 768px) {
      #mobile-topbar { display: none !important; }
      #sidebar-overlay { display: none !important; }
    }
  </style>
  <script is:inline>
    (function() {
      var lang = localStorage.getItem('wiki_lang') || 'en';
      document.documentElement.setAttribute('data-lang', lang);
    })();
  </script>
</head>
<body class="bg-dark text-[var(--text)]">

  <!-- Mobile top bar -->
  <div id="mobile-topbar" class="fixed top-0 left-0 right-0 z-50 h-14 items-center justify-between px-4 border-b border-[var(--border)]"
       style="background: rgba(13,13,26,0.96); backdrop-filter: blur(12px);">
    <a href={base + '/'} class="font-black text-white flex items-center gap-1.5 no-underline text-sm">
      <span class="text-primary">✦</span>
      <span>Balatro Odyssey Wiki</span>
    </a>
    <div class="flex items-center gap-2">
      <LangToggle />
      <button id="sidebar-toggle" aria-label="Menu" class="text-muted hover:text-white p-1 rounded transition-colors">
        <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6"  x2="19" y2="6"/>
          <line x1="3" y1="12" x2="19" y2="12"/>
          <line x1="3" y1="18" x2="19" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Sidebar overlay (mobile) -->
  <div id="sidebar-overlay"></div>

  <!-- Sidebar -->
  <aside id="sidebar">
    <!-- Logo -->
    <div class="flex items-center gap-2.5 px-5 h-16 border-b border-[var(--border)] shrink-0">
      <a href={base + '/'} class="font-black text-white flex items-center gap-2 no-underline hover:text-accent transition-colors">
        <span class="text-primary text-xl leading-none">✦</span>
        <span class="text-sm leading-tight">Balatro<br><span class="text-accent">Odyssey</span> Wiki</span>
      </a>
    </div>

    <!-- Nav -->
    <nav class="flex-1 overflow-y-auto py-3 px-2">
      <p class="text-[0.65rem] font-bold uppercase tracking-widest text-muted px-3 mb-2 mt-1">
        <span class="lang-en">Content</span>
        <span class="lang-pt">Conteúdo</span>
      </p>
      <ul class="list-none space-y-0.5">
        {navItems.map(item => {
          const active = isActive(item.href as string);
          if (item.disabled) {
            return (
              <li>
                <span class="flex items-center justify-between px-3 py-2 rounded-lg text-[0.88rem] opacity-40 cursor-not-allowed select-none">
                  <span class="flex items-center gap-2.5">
                    <span class="text-base leading-none w-5 text-center shrink-0">{item.icon}</span>
                    <span>
                      <span class="lang-en">{item.label_en}</span>
                      <span class="lang-pt">{item.label_pt}</span>
                    </span>
                  </span>
                  {item.soon && (
                    <span class="text-[0.6rem] font-bold uppercase tracking-wider px-1.5 py-0.5 rounded border border-[var(--border)] text-muted">
                      <span class="lang-en">Soon</span>
                      <span class="lang-pt">Em Breve</span>
                    </span>
                  )}
                </span>
              </li>
            );
          }
          return (
            <li>
              <a
                href={item.href as string}
                class:list={[
                  'flex items-center justify-between px-3 py-2 rounded-lg text-[0.88rem] no-underline transition-all duration-150 group',
                  active ? 'bg-primary/20 text-white font-semibold' : (item.lore ? 'text-accent hover:bg-dark3 hover:brightness-110 font-semibold' : 'text-muted hover:bg-dark3 hover:text-white')
                ]}
              >
                <span class="flex items-center gap-2.5">
                  <span class="text-base leading-none w-5 text-center shrink-0">{item.icon}</span>
                  <span>
                    <span class="lang-en">{item.label_en}</span>
                    <span class="lang-pt">{item.label_pt}</span>
                  </span>
                </span>
                {item.count && (
                  <span class:list={[
                    'text-[0.68rem] font-bold px-1.5 py-0.5 rounded-full shrink-0',
                    active ? 'bg-primary text-white' : 'bg-dark3 text-muted group-hover:bg-dark3'
                  ]}>{item.count}</span>
                )}
              </a>
            </li>
          );
        })}
      </ul>

      <hr class="my-4 border-[var(--border)]" />

      <p class="text-[0.65rem] font-bold uppercase tracking-widest text-muted px-3 mb-2">Links</p>
      <ul class="list-none space-y-0.5">
        <li>
          <a href="https://github.com/fenomelini/balatro-odyssey" target="_blank" rel="noopener"
             class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-[0.88rem] text-muted hover:bg-dark3 hover:text-white no-underline transition-all">
            <span class="text-base w-5 text-center">⭐</span>
            <span class="lang-en">GitHub Repo</span>
            <span class="lang-pt">Repositório</span>
          </a>
        </li>
        <li>
          <a href="https://www.nexusmods.com/balatro/mods/726" target="_blank" rel="noopener"
             class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-[0.88rem] text-muted hover:bg-dark3 hover:text-white no-underline transition-all">
            <span class="text-base w-5 text-center">🔗</span>
            <span>Nexus Mods</span>
          </a>
        </li>
      </ul>
    </nav>

    <!-- Lang toggle -->
    <div class="p-4 border-t border-[var(--border)] shrink-0">
      <LangToggle />
    </div>
  </aside>

  <!-- Main content -->
  <div id="main-area">
    <main><slot /></main>
    <footer class="text-center py-6 px-8 text-muted text-[0.8rem] border-t border-[var(--border)]">
      <p>
        Balatro Odyssey Wiki — fan-made reference. Not affiliated with LocalThunk.
        <br/>
        Content from the <a href="https://github.com/fenomelini/balatro-odyssey" class="text-accent hover:underline" target="_blank" rel="noopener">Balatro Odyssey mod</a> by fenomelini.
      </p>
    </footer>
  </div>

  <script>
    import '/src/utils/lang.ts';
  </script>
  <script is:inline>
    const toggle = document.getElementById('sidebar-toggle');
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebar-overlay');
    function openSidebar() {
      sidebar.classList.add('open');
      overlay.classList.add('open');
    }
    function closeSidebar() {
      sidebar.classList.remove('open');
      overlay.classList.remove('open');
    }
    toggle?.addEventListener('click', openSidebar);
    overlay?.addEventListener('click', closeSidebar);
    // Close sidebar when a nav link is tapped on mobile
    sidebar?.querySelectorAll('a[href]').forEach(function(link) {
      link.addEventListener('click', closeSidebar);
    });
  </script>
</body>
</html>
