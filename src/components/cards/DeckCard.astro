---
import { stripDescription } from '../../utils/formatDescription';

interface Props {
  deck: {
    key: string;
    sprite: string;
    name_en: string;
    name_pt: string;
    desc_en: string[];
    desc_pt: string[];
  };
  linkable?: boolean;
}

const { deck, linkable = true } = Astro.props;
const descEn = stripDescription(deck.desc_en);
const descPt = stripDescription(deck.desc_pt);
---

{linkable ? (
  <a
    href={`/decks/${deck.key}`}
    class="deck-card block rounded-2xl p-2 border border-transparent bg-transparent hover:bg-card hover:border-primary hover:-translate-y-1 transition-all duration-200 no-underline cursor-pointer"
    data-name-en={deck.name_en.toLowerCase()}
    data-name-pt={deck.name_pt.toLowerCase()}
  >
    <div class="flex justify-center mb-3">
      <img
        src={`/assets/${deck.sprite}`}
        alt={deck.name_en}
        width="142"
        height="190"
        loading="lazy"
        class="drop-shadow-[0_4px_12px_rgba(108,71,255,0.3)]"
        onerror="this.classList.add('sprite-error')"
      />
    </div>
    <div class="text-center mb-2 flex flex-col justify-center min-h-[2.5rem]">
      <span class="lang-en block text-[1rem] font-bold text-white leading-tight">{deck.name_en}</span>
      <span class="lang-pt block text-[1rem] font-bold text-white leading-tight">{deck.name_pt}</span>
    </div>
    <div class="rounded-lg p-2 bg-dark3/70 border border-[rgba(108,71,255,0.15)] text-[0.78rem] text-muted leading-snug">
      <span class="lang-en">{descEn}</span>
      <span class="lang-pt">{descPt}</span>
    </div>
  </a>
) : (
  <div
    class="deck-card rounded-2xl p-2 border border-transparent bg-transparent"
    data-name-en={deck.name_en.toLowerCase()}
    data-name-pt={deck.name_pt.toLowerCase()}
  >
    <div class="flex justify-center mb-3">
      <img
        src={`/assets/${deck.sprite}`}
        alt={deck.name_en}
        width="142"
        height="190"
        loading="lazy"
        class="drop-shadow-[0_4px_12px_rgba(108,71,255,0.3)]"
        onerror="this.classList.add('sprite-error')"
      />
    </div>
    <div class="text-center mb-2 flex flex-col justify-center min-h-[2.5rem]">
      <span class="lang-en block text-[1rem] font-bold text-white leading-tight">{deck.name_en}</span>
      <span class="lang-pt block text-[1rem] font-bold text-white leading-tight">{deck.name_pt}</span>
    </div>
    <div class="rounded-lg p-2 bg-dark3/70 border border-[rgba(108,71,255,0.15)] text-[0.78rem] text-muted leading-snug">
      <span class="lang-en">{descEn}</span>
      <span class="lang-pt">{descPt}</span>
    </div>
  </div>
)}
