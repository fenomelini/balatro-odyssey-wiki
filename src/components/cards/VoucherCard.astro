---
import { stripDescription } from '../../utils/formatDescription';

interface Props {
  voucher: {
    key: string;
    tier: number;
    pair_key?: string | null;
    sprite: string;
    name_en: string;
    name_pt: string;
    desc_en: string[];
    desc_pt: string[];
    cost: number;
  };
}

const { voucher } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const descEn = stripDescription(voucher.desc_en);
const descPt = stripDescription(voucher.desc_pt);
const tierColor = voucher.tier === 2 ? 'text-yellow-400 bg-yellow-400/10 border-yellow-400' : 'text-blue-300 bg-blue-400/10 border-blue-400';
---

<div
  class="voucher-card rounded-2xl p-2 border border-transparent bg-transparent hover:bg-card hover:border-primary hover:-translate-y-1 transition-all duration-200"
  data-name-en={voucher.name_en.toLowerCase()}
  data-name-pt={voucher.name_pt.toLowerCase()}
  data-tier={voucher.tier}
>
  <!-- Sprite -->
  <div class="flex justify-center mb-3">
    <img
      src={`${base}/assets/${voucher.sprite}`}
      alt={voucher.name_en}
      width="142"
      height="190"
      loading="lazy"
      onerror="this.classList.add('sprite-error')"
    />
  </div>

  <!-- Tier badge -->
  <div class="flex justify-center mb-2 gap-2">
    <span class={`text-[0.72rem] font-bold uppercase tracking-wide px-2 py-0.5 rounded-full border ${tierColor}`}>
      <span class="lang-en">{voucher.tier === 1 ? 'Base' : 'Upgrade'}</span>
      <span class="lang-pt">{voucher.tier === 1 ? 'Base' : 'Melhoria'}</span>
    </span>
  </div>

  <!-- Name -->
  <div class="text-center mb-2 flex flex-col justify-center min-h-[2.5rem]">
    <span class="lang-en block text-[1rem] font-bold text-white leading-tight">{voucher.name_en}</span>
    <span class="lang-pt block text-[1rem] font-bold text-white leading-tight">{voucher.name_pt}</span>
  </div>

  <!-- Description -->
  <div class="rounded-lg p-3 bg-dark3/70 border border-[rgba(108,71,255,0.15)] text-[0.82rem] text-muted leading-snug mb-4">
    <span class="lang-en">{descEn}</span>
    <span class="lang-pt">{descPt}</span>
  </div>

  <!-- Footer: pair + cost -->
  <div class="flex items-center justify-between">
    {voucher.pair_key && (
      <span class="text-[0.72rem] text-muted truncate max-w-[60%]">
        <span class="lang-en">Pairs: {voucher.pair_key.replace(/_/g, ' ')}</span>
        <span class="lang-pt">Par: {voucher.pair_key.replace(/_/g, ' ')}</span>
      </span>
    )}
    <span class="text-muted text-[0.82rem] font-bold ml-auto">${voucher.cost}</span>
  </div>
</div>
