---
import { stripDescription } from '../../utils/formatDescription';

interface Props {
  item: {
    id: number;
    type: 'tarot' | 'planet' | 'spectral';
    sprite: string;
    name_en: string;
    name_pt: string;
    desc_en: string[];
    desc_pt: string[];
    max_hand?: number;
    vars?: (number | string | null)[];
    hand?: string;
  };
}

const { item } = Astro.props;
const planetVars = item.type === 'planet' && item.hand ? [item.hand] : undefined;
const descEn = stripDescription(item.desc_en, planetVars);
const descPt = stripDescription(item.desc_pt, planetVars);

const typeColors: Record<string, string> = {
  tarot:    'text-purple-400 bg-purple-400/10',
  planet:   'text-blue-400 bg-blue-400/10',
  spectral: 'text-cyan-400 bg-cyan-400/10',
};
const typeColor = typeColors[item.type] ?? 'text-muted bg-dark3';
const typeLabel = item.type.charAt(0).toUpperCase() + item.type.slice(1);
const spriteGlow: Record<string, string> = {
  tarot:    '0_4px_12px_rgba(168,85,247,0.4)',
  planet:   '0_4px_12px_rgba(59,130,246,0.4)',
  spectral: '0_4px_12px_rgba(0,212,210,0.4)',
};
---

<div
  class="consumable-card rounded-2xl p-2 border border-transparent bg-transparent hover:bg-card hover:border-primary hover:-translate-y-1 transition-all duration-200"
  data-name-en={item.name_en.toLowerCase()}
  data-name-pt={item.name_pt.toLowerCase()}
>
  <!-- Sprite -->
  <div class="flex justify-center mb-3">
    <img
      src={`/assets/${item.sprite}`}
      alt={item.name_en}
      width="142"
      height="190"
      loading="lazy"
      class={`drop-shadow-[${spriteGlow[item.type]}]`}
      onerror="this.classList.add('sprite-error')"
    />
  </div>

  <!-- Type badge -->
  <div class="flex justify-center mb-2">
    <span class={`text-[0.72rem] font-bold uppercase tracking-wide px-2 py-0.5 rounded ${typeColor}`}>
      {typeLabel} #{item.id}
    </span>
  </div>

  <!-- Name -->
  <div class="text-center mb-2 flex flex-col justify-center min-h-[2.5rem]">
    <span class="lang-en block text-[1rem] font-bold text-white leading-tight">{item.name_en}</span>
    <span class="lang-pt block text-[1rem] font-bold text-white leading-tight">{item.name_pt}</span>
  </div>

  <!-- Description -->
  <div class="rounded-lg p-2 bg-dark3/70 border border-[rgba(108,71,255,0.15)] text-[0.78rem] text-muted leading-snug">
    <span class="lang-en">{descEn}</span>
    <span class="lang-pt">{descPt}</span>
  </div>
</div>
